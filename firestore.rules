rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user is admin
    // You can add admin check logic here based on your auth system
    function isAdmin() {
      return isAuthenticated(); // Modify this to check for admin role
    }
    
    // Voters collection - readable by admin, writable by authenticated users
    match /voters/{voterId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && request.resource.id == request.auth.uid;
      allow delete: if isAdmin();
    }
    
    // Candidates collection - readable by all, writable only by admin
    match /candidates/{candidateId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Votes collection - readable by admin, writable by authenticated users
    // Each user can only vote once
    match /votes/{voteId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && request.resource.data.voterId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Prevent any other collection access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
